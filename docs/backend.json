
{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "type": "object",
      "description": "User profile information.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "languagePreference": { "type": "string", "enum": ["KJV", "IRV_HIN"] },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Bookmark": {
      "title": "Bookmark",
      "type": "object",
      "description": "Saved Bible verses.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "verseId": { "type": "string" },
        "verseText": { "type": "string" },
        "bookName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "PrayerRequest": {
      "title": "PrayerRequest",
      "type": "object",
      "description": "Community or private prayers.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "content": { "type": "string" },
        "type": { "type": "string", "enum": ["public", "private"] },
        "amenCount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Note": {
      "title": "Note",
      "type": "object",
      "description": "Personal study notes on verses.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "verseId": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "/users/{userId}": { "schema": "UserProfile", "description": "User profile" },
    "/users/{userId}/bookmarks/{bookmarkId}": { "schema": "Bookmark", "description": "User bookmarks" },
    "/users/{userId}/notes/{noteId}": { "schema": "Note", "description": "Personal study notes" },
    "/community_prayers/{prayerId}": { "schema": "PrayerRequest", "description": "Public prayer requests" }
  }
}
