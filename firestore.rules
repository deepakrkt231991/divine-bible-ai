/**
 * This ruleset enforces a security model for the BibleAI Companion application.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --------------------------------------------------------------------
    // Helper Functions
    // --------------------------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    function newDocHasCorrectUserId(userId) {
      return request.resource.data.userId == userId;
    }
    
    function userIdIsImmutable() {
      return request.resource.data.userId == resource.data.userId;
    }

    // --------------------------------------------------------------------
    // User Data
    // --------------------------------------------------------------------

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if false; 
      allow create: if isOwner(userId) && request.resource.data.uid == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.uid == resource.data.uid;
      allow delete: if isExistingOwner(userId);
    }

    match /users/{userId}/bibleNotes/{noteId} {
      allow get, list: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && newDocHasCorrectUserId(userId);
      allow update: if isExistingOwner(userId) && userIdIsImmutable();
      allow delete: if isExistingOwner(userId);
    }

    // --------------------------------------------------------------------
    // Public & Semi-Public Data
    // --------------------------------------------------------------------

    match /prayers/{prayerId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update, delete: if false;
    }

    match /daily_content/{contentId} {
      allow read: if true;
      allow create: if isSignedIn(); // Allow agent/admin to create
      allow update, delete: if isAdmin();
    }

    match /vpnSessions/{vpnSessionId} {
      allow get, list: if isAdmin();
      allow create: if isSignedIn() && request.resource.data.userIdOrHash == request.auth.uid;
      allow update: if false;
      allow delete: if false;
    }

    // --------------------------------------------------------------------
    // Administrative Collections
    // --------------------------------------------------------------------
    
    match /roles_admin/{userId} {
      allow get, list: if isAdmin();
      allow create, update, delete: if false;
    }
  }
}
