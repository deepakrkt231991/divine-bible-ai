rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // User Profile rules
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);

      match /bookmarks/{bookmarkId} {
        allow read, write: if isOwner(userId);
      }

      match /notes/{noteId} {
        allow read, write: if isOwner(userId);
      }

      match /reading_progress/{planId} {
        allow read, write: if isOwner(userId);
      }
    }

    // Community Prayers rules
    match /community_prayers/{prayerId} {
      // Allow everyone to read the feed
      allow read: if true;
      // Allow only signed-in users to create prayers
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      // Allow signed-in users to update (for Amen count)
      allow update: if isSignedIn();
      // Allow only the owner to delete their prayer
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // Reading Plans metadata
    match /reading_plans/{planId} {
      allow read: if true;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}